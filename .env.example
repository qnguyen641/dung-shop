# ─── VNPay Keys ───────────────────────────────────────────────────────────────
# Lấy tại: https://sandbox.vnpayment.vn/devreg → Đăng ký tài khoản sandbox
# Production: https://vnpayment.vn → liên hệ VNPay để lấy tmnCode + secureSecret
VNPAY_TMN_CODE=YOUR_TMN_CODE
VNPAY_SECURE_SECRET=YOUR_SECURE_SECRET
# Sandbox: https://sandbox.vnpayment.vn | Production: https://vnpayment.vn
VNPAY_HOST=https://sandbox.vnpayment.vn

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Lấy tại: https://supabase.com → Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Server Config ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# URL public của server (VNPay cần URL này để gọi IPN và return)
# Dùng ngrok khi test local: ngrok http 3000 → lấy URL ngrok điền vào đây
BASE_URL=https://your-domain.com

